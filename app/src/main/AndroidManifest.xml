<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- NFC -->
    <uses-permission android:name="android.permission.NFC" />
    <uses-feature android:name="android.hardware.nfc" android:required="true" />

    <!-- Camera -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="true" />
    <uses-feature android:name="android.hardware.camera.autofocus" android:required="false" />

    <!-- Storage (for saving photos) -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />

    <application
        android:name=".MainApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CCCDReader"
        android:hardwareAccelerated="true">

        <!-- Main Entry Screen -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Camera capture activity -->
        <activity
            android:name=".camera.CameraActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- NFC reader activity.
             Uses NFC Reader Mode (enableReaderMode) rather than Foreground Dispatch,
             so no TECH_DISCOVERED intent filter is needed – the tag is delivered
             directly to the ReaderCallback without the NFC stack running NDEF
             detection first (which times out on eMRTD chips and corrupts the channel). -->
        <activity
            android:name=".nfc.NFCReaderActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Manual MRZ input activity -->
        <activity
            android:name=".ui.MRZInputActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <!-- Results display activity -->
        <activity
            android:name=".ui.ResultActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

    </application>
</manifest>
