<?xml version="1.0" encoding="utf-8"?>
<!--
    CCCD Reader – adaptive icon foreground
    Canvas : 108 × 108 dp
    Safe zone (always visible, any launcher shape): x=18..90, y=18..90

    Design:
      • White rounded-rectangle ID card
      • Light-blue header stripe with gold 5-point star (Vietnamese flag nod)
      • Gold EMV chip with contact grid
      • Three NFC arcs + dot in Vietnamese blue
      • Two data-field indicator bars
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ── Card body (white, rounded rectangle) ──────────────────────────── -->
    <!--  x=16, y=24, w=76, h=60, rx=10                                      -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M26,24 L82,24 A10,10,0,0,1,92,34 L92,74 A10,10,0,0,1,82,84 L26,84 A10,10,0,0,1,16,74 L16,34 A10,10,0,0,1,26,24 Z" />

    <!-- ── Card header stripe (light blue, top 16dp of card) ─────────────── -->
    <path
        android:fillColor="#1565C0"
        android:fillAlpha="0.13"
        android:pathData="M26,24 L82,24 A10,10,0,0,1,92,34 L92,40 L16,40 L16,34 A10,10,0,0,1,26,24 Z" />

    <!-- ── Vietnamese 5-point star (top-right of header, gold) ───────────── -->
    <!--  Centered at (80, 33), outer r=5.5, inner r=2.2                     -->
    <path
        android:fillColor="#FDD835"
        android:pathData="
          M80.0,27.5
          L81.3,31.2 L85.2,31.2
          L82.2,33.5 L83.3,37.3
          L80.0,35.1 L76.7,37.3
          L77.8,33.5 L74.8,31.2
          L78.7,31.2 Z" />

    <!-- ── EMV chip body (gold) ───────────────────────────────────────────── -->
    <!--  x=22, y=34, w=24, h=18, rx=3                                       -->
    <path
        android:fillColor="#FDD835"
        android:pathData="M25,34 L43,34 A3,3,0,0,1,46,37 L46,49 A3,3,0,0,1,43,52 L25,52 A3,3,0,0,1,22,49 L22,37 A3,3,0,0,1,25,34 Z" />

    <!-- Chip contact grid – vertical lines -->
    <path
        android:strokeColor="#F57F17"
        android:strokeWidth="0.9"
        android:fillColor="#00000000"
        android:pathData="M28,34 L28,52 M33,34 L33,52 M38,34 L38,52 M43,34 L43,52" />

    <!-- Chip contact grid – horizontal lines -->
    <path
        android:strokeColor="#F57F17"
        android:strokeWidth="0.9"
        android:fillColor="#00000000"
        android:pathData="M22,39 L46,39 M22,43 L46,43 M22,47 L46,47" />

    <!-- Chip centre square (darker gold, simulates SIM contact pad) -->
    <path
        android:fillColor="#F9A825"
        android:pathData="M32,39 L38,39 L38,47 L32,47 Z" />

    <!-- ── NFC symbol ────────────────────────────────────────────────────── -->
    <!--  Centre dot at (62, 43); arcs open rightward                        -->

    <!-- Dot -->
    <path
        android:fillColor="#1565C0"
        android:pathData="M64.5,43 A2.5,2.5,0,1,1,59.5,43 A2.5,2.5,0,1,1,64.5,43 Z" />

    <!-- Arc 1 – inner (r=6, chord from y=38 to y=48) -->
    <path
        android:strokeColor="#1565C0"
        android:strokeWidth="2.8"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M62,38 A6,6,0,0,1,62,48" />

    <!-- Arc 2 – middle (r=10, chord from y=34 to y=52) -->
    <path
        android:strokeColor="#1565C0"
        android:strokeWidth="2.8"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:fillAlpha="0.0"
        android:strokeAlpha="0.72"
        android:pathData="M62,34 A10,10,0,0,1,62,52" />

    <!-- Arc 3 – outer (r=14, chord from y=30 to y=56) -->
    <path
        android:strokeColor="#1565C0"
        android:strokeWidth="2.8"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:strokeAlpha="0.44"
        android:pathData="M62,30 A14,14,0,0,1,62,56" />

    <!-- ── Data field bars (simulate MRZ / text lines on card) ──────────── -->
    <!-- Full-width bar -->
    <path
        android:fillColor="#90CAF9"
        android:pathData="M22,62 L86,62 A2,2,0,0,1,88,64 L88,67 A2,2,0,0,1,86,69 L22,69 A2,2,0,0,1,20,67 L20,64 A2,2,0,0,1,22,62 Z" />

    <!-- Half-width bar -->
    <path
        android:fillColor="#90CAF9"
        android:fillAlpha="0.65"
        android:pathData="M22,72 L64,72 A2,2,0,0,1,66,74 L66,77 A2,2,0,0,1,64,79 L22,79 A2,2,0,0,1,20,77 L20,74 A2,2,0,0,1,22,72 Z" />

</vector>
