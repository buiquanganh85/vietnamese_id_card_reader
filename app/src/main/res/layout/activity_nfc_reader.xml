<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- ── Scanning state ─────────────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/layoutScanning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="32dp"
            android:paddingBottom="16dp">

            <ImageView
                android:id="@+id/ivNfcIcon"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:src="@drawable/ic_nfc_scan"
                android:layout_marginBottom="20dp" />

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:visibility="gone"
                android:layout_marginBottom="20dp" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Đặt thẻ CCCD lên mặt sau điện thoại\n\nPlace the CCCD card on the back of your phone near the NFC antenna"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:gravity="center"
                android:layout_marginBottom="10dp" />

            <TextView
                android:id="@+id/tvSubStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:visibility="gone"
                android:layout_marginBottom="16dp" />

        </LinearLayout>

        <!-- ── Error card ─────────────────────────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="10dp"
            app:cardBackgroundColor="#FFF3CD"
            android:visibility="gone"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚠  Lỗi đọc NFC / NFC Error"
                    android:textStyle="bold"
                    android:textColor="#856404"
                    android:textSize="14sp"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/tvErrorMessage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#856404"
                    android:textSize="12sp"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/btnRetry"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="Thử lại / Retry"
                    android:textAllCaps="false" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Decoded data card (shown after successful read) ────────────── -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:visibility="gone"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Header -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✅  Đọc chip thành công / Chip read successful"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="#1B5E20"
                    android:layout_marginBottom="16dp" />

                <!-- Face photo from chip -->
                <ImageView
                    android:id="@+id/ivFacePhoto"
                    android:layout_width="100dp"
                    android:layout_height="130dp"
                    android:layout_gravity="center_horizontal"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:id="@+id/tvNoFacePhoto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Không có ảnh khuôn mặt / No face photo"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:visibility="gone"
                    android:layout_marginBottom="12dp" />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E0E0E0"
                    android:layout_marginBottom="12dp" />

                <!-- Full name -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Họ và tên / Full Name"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:textAllCaps="true" />
                <TextView
                    android:id="@+id/tvFullName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="12dp" />

                <!-- Document number -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Số CCCD / Document Number"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:textAllCaps="true" />
                <TextView
                    android:id="@+id/tvDocNumber"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:fontFamily="monospace"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="12dp" />

                <!-- Date of birth -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ngày sinh / Date of Birth"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:textAllCaps="true" />
                <TextView
                    android:id="@+id/tvDob"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="12dp" />

                <!-- Sex -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Giới tính / Sex"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:textAllCaps="true" />
                <TextView
                    android:id="@+id/tvSex"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="12dp" />

                <!-- Nationality -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Quốc tịch / Nationality"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:textAllCaps="true" />
                <TextView
                    android:id="@+id/tvNationality"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="12dp" />

                <!-- Expiry -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hết hạn / Expiry Date"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:textAllCaps="true" />
                <TextView
                    android:id="@+id/tvExpiry"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="12dp" />

                <!-- Personal number (CCCD 12 digits) -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Số cá nhân / Personal Number"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:textAllCaps="true" />
                <TextView
                    android:id="@+id/tvPersonalNo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:fontFamily="monospace"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="16dp" />

                <!-- MRZ raw lines -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E0E0E0"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dữ liệu MRZ thô / Raw MRZ Data"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:textAllCaps="true"
                    android:layout_marginBottom="4dp" />
                <TextView
                    android:id="@+id/tvMrzLine1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:textColor="#333333"
                    android:background="#F5F5F5"
                    android:padding="6dp" />
                <TextView
                    android:id="@+id/tvMrzLine2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:textColor="#333333"
                    android:background="#F5F5F5"
                    android:padding="6dp" />
                <TextView
                    android:id="@+id/tvMrzLine3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:textColor="#333333"
                    android:background="#F5F5F5"
                    android:padding="6dp"
                    android:layout_marginBottom="8dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Action buttons ─────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <Button
                android:id="@+id/btnCancel"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Huỷ / Cancel"
                android:textAllCaps="false"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnDone"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="2"
                android:text="✓  Xong / Done"
                android:textAllCaps="false"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
