<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- NFC warning banner -->
        <TextView
            android:id="@+id/tvNfcWarning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/color_warning_bg"
            android:drawablePadding="6dp"
            android:padding="12dp"
            android:textColor="@color/color_warning_text"
            android:textSize="13sp"
            android:visibility="gone"
            android:layout_marginBottom="12dp" />

        <!-- ── App header ──────────────────────────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:background="@color/color_primary">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🪪 CCCD Reader"
                    android:textColor="@android:color/white"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đọc thông tin Căn Cước Công Dân qua NFC"
                    android:textColor="#CCffffff"
                    android:textSize="13sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── STEP 1: Front photo ─────────────────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="@color/surface"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:text="1"
                        android:textColor="@android:color/white"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@drawable/badge_step"
                        android:backgroundTint="@color/color_step1" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Chụp mặt TRƯỚC"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/color_step1"
                        android:layout_marginStart="12dp" />

                    <ImageView
                        android:id="@+id/ivStep1Check"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/checkbox_on_background"
                        android:visibility="invisible" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvStep1Status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chưa chụp"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/btnCaptureFront"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="📷  Chụp mặt trước"
                    android:textAllCaps="false"
                    app:backgroundTint="@color/color_step1" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── STEP 2: Back photo ──────────────────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="@color/surface"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:text="2"
                        android:textColor="@android:color/white"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@drawable/badge_step"
                        android:backgroundTint="@color/color_step2" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Chụp mặt SAU"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/color_step2"
                        android:layout_marginStart="12dp" />

                    <ImageView
                        android:id="@+id/ivStep2Check"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/checkbox_on_background"
                        android:visibility="invisible" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvStep2Status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chưa chụp"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/btnCaptureBack"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="📷  Chụp mặt sau"
                    android:textAllCaps="false"
                    app:backgroundTint="@color/color_step2" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── STEP 3: MRZ data entry ───────────────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="@color/surface"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:text="3"
                        android:textColor="@android:color/white"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@drawable/badge_step"
                        android:backgroundTint="@color/color_step3" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Nhập dữ liệu MRZ"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/color_step3"
                        android:layout_marginStart="12dp" />

                    <ImageView
                        android:id="@+id/ivStep3Check"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/checkbox_on_background"
                        android:visibility="invisible" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvStep3Status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chưa nhập"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nhập số CCCD, ngày sinh và ngày hết hạn để xác thực chip NFC"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/btnEnterMrz"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="✏️  Nhập thông tin MRZ"
                    android:textAllCaps="false"
                    app:backgroundTint="@color/color_step3" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── STEP 4: Read NFC ────────────────────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="@color/surface"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:text="4"
                        android:textColor="@android:color/white"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@drawable/badge_step"
                        android:backgroundTint="@color/color_step4" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Đọc chip NFC"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/color_step4"
                        android:layout_marginStart="12dp" />

                    <ImageView
                        android:id="@+id/ivStep4Check"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/checkbox_on_background"
                        android:visibility="invisible" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvStep4Status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chưa đọc"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/btnReadNfc"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="📡  Đọc NFC"
                    android:textAllCaps="false"
                    android:enabled="false"
                    app:backgroundTint="@color/color_step4" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── View Results ────────────────────────────────────────────────── -->
        <Button
            android:id="@+id/btnViewResults"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="📋  Xem kết quả / View Results"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:enabled="false"
            android:layout_marginBottom="24dp"
            app:backgroundTint="@color/color_primary" />

    </LinearLayout>
</ScrollView>
